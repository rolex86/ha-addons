HOST_PORT=8080
APP_ENV=production
ADDON_URL=http://RASPBERRYPI_IP:8080/manifest.json
ADDON_CONTACT=mailto:admin@example.invalid
REQUEST_DELAY_HELLSPY=0.5
REQUEST_DELAY_WIKIDATA=1.0
REQUEST_DELAY_OTHER=0.25
MAX_RETRIES=3
RETRY_DELAY_BASE=2.0
MAX_RETRY_BACKOFF=8.0
REQUEST_TIMEOUT=10
SEARCH_TIME_BUDGET_MS=7000
MAX_SEARCH_QUERIES=8
STREAM_RESOLVE_CONCURRENCY=2
STREAM_REQUEST_CACHE_TTL=120
STREAM_REQUEST_INFLIGHT_WAIT_MS=8000
STREAM_REQUEST_INFLIGHT_POLL_MS=100
LOG_LEVEL=warn
LOG_HTTP_RESPONSE_BODY=false
