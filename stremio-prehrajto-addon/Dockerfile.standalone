FROM node:20-alpine

WORKDIR /app

COPY package.json /app/package.json
RUN npm install --omit=dev --no-audit --no-fund \
  && npm cache clean --force

COPY src /app/src
COPY README.md /app/README.md

ENV NODE_ENV=production
ENV PORT=7654
ENV DATA_DIR=/data

VOLUME ["/data"]

EXPOSE 7654

CMD ["node", "src/index.js"]
